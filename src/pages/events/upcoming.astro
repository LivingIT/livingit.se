---
export const prerender = false;

import { apiFetch } from '../../lib/api';
import type { ApiEvent } from '../../types/api';
import { getTranslations } from '../../i18n';
import Layout from '../../components/Layout.astro';
import EventCard from '../../components/EventCard.astro';

const t = getTranslations('sv');

let events: ApiEvent[] | null = null;
let fetchFailed = false;

try {
  const response = await apiFetch('/api/events/public');
  if (response.ok) {
    const allEvents = await response.json() as ApiEvent[];
    events = allEvents.filter((e) => e.isActive);
  } else {
    fetchFailed = true;
  }
} catch (err) {
  console.error('[upcoming] fetch threw:', err);
  fetchFailed = true;
}

if (fetchFailed) {
  Astro.response.status = 500;
}
---
<Layout title="Kommande evenemang | Living IT" description="Bläddra bland kommande evenemang från Living IT.">
  <main class="min-h-screen">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="mt-12 mb-12">
        <h1 class="text-5xl font-bold mb-8 text-center">{t.nav.upcomingEvents}</h1>
      </div>

      <section>
        {fetchFailed && (
          <p class="text-mono-dark">{t.error.somethingWentWrong}</p>
        )}

        {!fetchFailed && events !== null && events.length === 0 && (
          <p class="text-mono-dark">{t.error.noActiveEvents}</p>
        )}

        {!fetchFailed && events !== null && events.length > 0 && (
          <ul class="grid grid-cols-1 gap-8 md:grid-cols-2">
            {events.map((event) => (
              <li class="[&:last-child:nth-child(odd)]:col-span-full"><EventCard event={event} lang={event.language} /></li>
            ))}
          </ul>
        )}
      </section>
    </div>
  </main>
</Layout>
