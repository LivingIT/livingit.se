---
export const prerender = false;

import { apiFetch } from '../../lib/api';
import type { ApiEvent, EventStatus } from '../../types/api';
import { getTranslations } from '../../i18n';
import Layout from '../../components/Layout.astro';
import EventStatusBadge from '../../components/EventStatusBadge.astro';

const { slug } = Astro.params as { slug: string };

const response = await apiFetch(`/api/events/public/${slug}`);

if (!response.ok) {
  Astro.response.status = response.status === 404 ? 404 : 500;
}

const event: ApiEvent | null = response.ok
  ? (await response.json() as ApiEvent)
  : null;

const is404 = !response.ok && response.status === 404;

const status: EventStatus | null = event
  ? (event.isSoldOut ? 'full' : event.isActive ? 'upcoming' : 'past')
  : null;

const showRegistrationPlaceholder = event?.isActive ?? false;

const isOneDayEvent = event
  ? new Intl.DateTimeFormat('sv-SE', { dateStyle: 'short', timeZone: 'Europe/Stockholm' }).format(new Date(event.startDateTime))
    === new Intl.DateTimeFormat('sv-SE', { dateStyle: 'short', timeZone: 'Europe/Stockholm' }).format(new Date(event.endDateTime))
  : false;

const t = event ? getTranslations(event.language) : getTranslations('sv');

function formatDate(isoDate: string, lang: 'sv' | 'en', options: Intl.DateTimeFormatOptions): string {
  try {
    const d = new Date(isoDate);
    if (isNaN(d.getTime())) throw new RangeError('invalid');
    return new Intl.DateTimeFormat(lang === 'sv' ? 'sv-SE' : 'en-GB', { ...options, timeZone: 'Europe/Stockholm' }).format(d);
  } catch {
    return isoDate;
  }
}

const startFormatted = event
  ? formatDate(event.startDateTime, event.language, { dateStyle: 'long', timeStyle: 'short' })
  : '';
const endFormatted = event
  ? formatDate(event.endDateTime, event.language, isOneDayEvent ? { timeStyle: 'short' } : { dateStyle: 'long', timeStyle: 'short' })
  : '';

const pageTitle = event ? `${event.title} - Living IT Event` : 'Living IT Event';
const pageDescription = event
  ? event.description.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 160)
  : undefined;
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="min-h-screen">

    {is404 && (
      <section class="error-section">
        <p class="error-message">{t.event.notFound}</p>
        <a href="/events" class="error-back-link">{t.nav.backToEvents}</a>
      </section>
    )}

    {!event && !is404 && (
      <section class="error-section">
        <p class="error-message">{t.error.somethingWentWrong}</p>
        <a href="/events" class="error-back-link">{t.nav.backToEvents}</a>
      </section>
    )}

    {event && status && (
      <div class="mx-auto max-w-7xl px-4 pt-20 sm:px-6 lg:px-8">
        <div class="mt-12">
          <h1 class="text-5xl font-bold mb-8 text-center">{event.title}</h1>
        </div>
      </div>
    )}

    {event && (
      <section class="promotion">
        <div class="section__content">
          <img class="promotion__img" src={event.imageUrl} alt={t.common.eventPromotion} />
        </div>
      </section>
    )}

    {event && status && (
      <section class="section">
        <div class="section__content content">
        <div class="event">

          <div class="event__details">
            <h2>{t.common.timeAndLocation}</h2>
            <p class="event__time-range">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
                <line x1="16" x2="16" y1="2" y2="6" />
                <line x1="8" x2="8" y1="2" y2="6" />
                <line x1="3" x2="21" y1="10" y2="10" />
              </svg>
              {startFormatted} - {endFormatted}
            </p>
            <p class="event__location">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              <span class="event__city-chip">{event.city}</span>
              <a
                href={event.geo.googlePlaceId
                ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(event.location)}&query_place_id=${event.geo.googlePlaceId}`
                : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(event.location + ', Sweden')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="event__location-link"
                aria-label={`${event.location} (${t.common.opensInGoogleMaps})`}
              >{event.location}</a>
            </p>
            {event.price && event.price.ticketPrice > 0 && (
              <p class="event__price">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="10" />
                  <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8" />
                  <path d="M12 18V6" />
                </svg>
                {event.price.ticketPrice} {t.price.sek} ({t.price.includingVat.replace('{{percentage}}', String(event.price.vatPercentage))})
              </p>
            )}
          </div>

          <div class="event__description" set:html={event.description} />
          {event.agenda && <div class="event__agenda" set:html={event.agenda} />}
        </div>

        <div class="reservation">
          <a href="/events" class="back-link">{t.nav.backToEvents}</a>
          {showRegistrationPlaceholder && (
            <div id="registration-form-placeholder">
              {/* TODO Story 3.2: Replace this with:
                  <RegistrationForm
                    event={event}
                    lang={event.language}
                    translations={t}
                  />
              */}
              <p class="placeholder-text">{t.form.submitButton}</p>
            </div>
          )}
        </div>
      </div>
    </section>
    )}
  </main>
</Layout>

<style>
.error-section {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 1rem;
  }

  .error-message {
    font-size: 1.25rem;
    color: var(--color-mono-dark);
    margin-bottom: 1.5rem;
  }

  .error-back-link {
    color: var(--color-orange);
    text-decoration: underline;
  }

  .section__content {
    max-width: 65rem;
    margin: auto;
  }

  .promotion {
    padding: 0 1rem 0.5rem;
  }

  .promotion > .section__content {
    padding: 0;
  }

  .section {
    padding: 2rem 1rem 4rem;
  }

  .promotion__img {
    width: 100%;
    height: auto;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .event {
    flex: 2;
  }

.event__details {
    margin-top: 1.5rem;
  }

  .event__details h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .event__city-chip {
    display: inline-block;
    background-color: var(--color-orange);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    flex-shrink: 0;
  }

  .event__time-range,
  .event__location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .event__location-link {
    flex: 1;
    color: var(--color-orange);
    text-decoration: underline;
  }

  .event__location-link:hover {
    text-decoration: none;
  }

  .event__location-link:focus-visible {
    outline: 2px solid var(--color-orange);
    outline-offset: 2px;
    border-radius: 2px;
    text-decoration: none;
  }

  .event__price {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .event__description,
  .event__agenda {
    margin-top: 1.5rem;
  }

  .event__description :global(p),
  .event__agenda :global(p) {
    margin-bottom: 1rem;
    max-width: 75%;
  }

  .event__description :global(a),
  .event__agenda :global(a) {
    color: var(--color-orange);
  }

  .reservation {
    flex: 1;
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-mono-lighter);
    border-radius: 0.75rem;
    padding: 2rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.10);
    margin-top: 2rem;
  }

  .placeholder-text {
    font-style: italic;
    color: var(--color-mono-gray);
    padding: 1rem;
    border: 1px dashed var(--color-mono-gray);
    border-radius: 0.5rem;
  }

  .back-link {
    color: var(--color-orange);
    text-decoration: underline;
  }

  @media (min-width: 768px) {
    .section__content {
      padding: 0 1rem;
    }

    .promotion > .section__content {
      padding: 0 1rem;
    }

    .section {
      padding: 2rem 0 4rem;
    }

    .promotion {
      padding: 0 0 0.5rem;
    }

    .promotion__img {
      height: 100%;
      border-radius: 1rem;
    }

    .content {
      flex-direction: row;
    }

    .reservation {
      margin-top: 3rem;
      align-self: flex-start;
    }
  }
</style>
