{
  "name": "livingit-se",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/copy-robots.mjs && astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.6",
    "@iconify-json/simple-icons": "^1.2.75",
    "astro": "^6.1.2",
    "astro-icon": "^1.1.5",
    "lucide-astro": "^0.556.0",
    "marked": "^17.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.2.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4.2.2",
    "wrangler": "^4.78.0"
  },
  "prettier": {
    "bracketSpacing": true,
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  }
}
